# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# IDE
.vscode/
.idea/
*.swp

# Project artefacts (these are generated — keep the dirs but ignore contents)
models/*.pkl
logs/*.csv
logs/*.json
plots/*.png

# Keep the directory placeholders so git tracks the folder structure
!models/.gitkeep
!logs/.gitkeep
!plots/.gitkeep

# Streamlit / pyvis temp files
.pyvis_tmp.html
.streamlit/

# MLflow run artefacts (local file store — can grow large)
mlruns/

# DVC cache and temporary files
.dvc/cache/
.dvc/tmp/
.dvc/.gitignore

# Policy snapshots (versioned separately via rollback.py)
models/snapshots/*.pkl
models/snapshots/*.json
!models/snapshots/.gitkeep

# Deploy log (generated by CD workflow)
deploy.log

# OS
.DS_Store
Thumbs.db
